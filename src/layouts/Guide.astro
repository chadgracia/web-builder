---
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description?: string;
  slug: string;
  canonical?: string;
}

const { title, description, slug, canonical } = Astro.props;
const tradesUrl = `https://trades.graciagroup.com/?src=${slug}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="stylesheet" href="https://s3.us-east-1.amazonaws.com/main.css/master.css" />
  </head>
  <body>
    <Header tradesUrl={tradesUrl} />

    <main class="guide">
      <article class="report">
        <slot />
      </article>
      <aside class="deal-panel" aria-hidden="true">
        <!-- Reserved for live deal data -->
      </aside>
    </main>

    <footer class="site-footer">
      <a class="btn" href={tradesUrl}>Work with Gracia Group</a>
    </footer>
  </body>
</html>

<style>
  .guide {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 2rem;
    max-width: 64rem;
    margin: 0 auto;
    padding: 2rem;
  }

  .deal-panel {
    border: 1px dashed var(--border, #c4c4c4);
    border-radius: 8px;
    background: #fafafa;
    min-height: 200px;
  }

  .site-footer {
    padding: 2rem;
    border-top: 1px solid var(--border, #e5e5e5);
    text-align: center;
  }

  @media (max-width: 720px) {
    .guide {
      grid-template-columns: 1fr;
    }
  }
</style>
