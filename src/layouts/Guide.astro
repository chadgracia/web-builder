---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">Gracia Group</a>
    </header>

    <main class="guide">
      <article class="guide-body">
        <slot />
      </article>
      <aside class="deal-panel" aria-hidden="true">
        <!-- Reserved for live deal data -->
      </aside>
    </main>

    <footer class="site-footer">
      <a class="cta" href="/?src=guide">Work with Gracia Group</a>
    </footer>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family: system-ui, -apple-system, sans-serif;
    color: #1a1a1a;
    line-height: 1.6;
  }

  .site-header {
    padding: 1rem 2rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .brand {
    font-weight: 700;
    font-size: 1.25rem;
    color: inherit;
    text-decoration: none;
  }

  .guide {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 2rem;
    max-width: 64rem;
    margin: 0 auto;
    padding: 2rem;
  }

  .deal-panel {
    border: 1px dashed #c4c4c4;
    border-radius: 8px;
    background: #fafafa;
    min-height: 200px;
  }

  .site-footer {
    padding: 2rem;
    border-top: 1px solid #e5e5e5;
    text-align: center;
  }

  .cta {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    font-weight: 600;
  }

  @media (max-width: 720px) {
    .guide {
      grid-template-columns: 1fr;
    }
  }
</style>
