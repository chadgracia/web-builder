---
import { getCollection } from 'astro:content';
const companies = await getCollection('companies');
const notes = (await getCollection('notes')).sort(
  (a, b) => +new Date(b.data.date) - +new Date(a.data.date),
);
const learn = (await getCollection('learn')).sort(
  (a, b) => +new Date(a.data.date) - +new Date(b.data.date),
);

// Build a search index string from a few fields plus the full article body,
// so the homepage search matches on content (e.g. "prometheus"), not just titles.
const searchIndex = (...parts) => parts.filter(Boolean).join(' ').replace(/\s+/g, ' ').trim();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pre-IPO Research | Gracia Group</title>
    <meta name="description" content="Background research and live secondary-market indications on leading pre-IPO companies." />
    <link rel="stylesheet" href="https://s3.us-east-1.amazonaws.com/main.css/master.css" />
  </head>
  <body>
    <header class="header">
      <a class="brand" href="/">Gracia Group</a>
      <nav class="nav">
        <a class="btn" href="https://trades.graciagroup.com/?src=home">Live Trading Book &rarr;</a>
      </nav>
    </header>
    <main class="page">
      <h1>Pre-IPO Research</h1>
      <p class="subtitle">Background research on leading private companies. For current bids, offers, and round status, visit the live trading book.</p>

      <input id="search" type="search" placeholder="Search companies, notes, ideas…" class="search-bar" autocomplete="off" />

      <section class="company-section" data-section>
        <h2>Private Company Notes</h2>
        <ul class="company-list">
          {companies.map((entry) => (
            <li data-search={searchIndex(entry.data.title, entry.data.sector, entry.data.blurb, entry.body)}>
              <a href={`/${entry.id}/`}>{entry.data.title}</a>
              {entry.data.sector && <span class="sec"> — {entry.data.sector}</span>}
            </li>
          ))}
        </ul>
      </section>

      {notes.length > 0 && (
        <section class="notes-section" data-section>
          <h2>Private Market Notes</h2>
          <ul class="company-list">
            {notes.map((entry) => (
              <li data-search={searchIndex(entry.data.title, entry.body)}>
                <a href={`/notes/${entry.id}/`}>{entry.data.title}</a>
                <span class="sec"> — {entry.data.date}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      {learn.length > 0 && (
        <section class="learn-section" data-section>
          <h2>Field Notes from the Frontlines</h2>
          <p class="subtitle">Big-picture essays on the private markets, drawn from years of working the secondaries desk.</p>
          <ul class="company-list">
            {learn.map((entry) => (
              <li data-search={searchIndex(entry.data.title, entry.body)}>
                <a href={`/learn/${entry.id}/`}>{entry.data.title}</a>
                <span class="sec"> — {entry.data.date}</span>
              </li>
            ))}
          </ul>
        </section>
      )}
    </main>
  </body>
</html>

<style>
  .header { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
  .brand { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; color: var(--ink); border-bottom: none; }
  .nav { display: flex; gap: 8px; align-items: center; }
  .page { padding: 40px; }
  .company-list { list-style: none; padding: 0; margin: 16px 0 0; }
  .company-list li { padding: 12px 0; border-bottom: 1px solid var(--border); }
  .sec { color: var(--text-muted); font-size: 14px; }
  .search-bar { display: block; width: 100%; box-sizing: border-box; margin: 20px 0 8px;
                padding: 10px 14px; font-size: 1rem; border: 1px solid var(--border);
                border-radius: 6px; background: var(--surface, #fff); color: var(--ink);
                outline-offset: 2px; }
  .search-bar:focus { outline: 2px solid var(--accent); border-color: transparent; }
  .notes-section { margin-top: 36px; }
  .learn-section { margin-top: 36px; }
  [data-section][hidden] { display: none; }
  @media (max-width: 640px) { .page { padding: 24px; } }
</style>

<script>
  const input = document.getElementById('search') as HTMLInputElement;
  const sections = document.querySelectorAll<HTMLElement>('[data-section]');

  input.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    sections.forEach((section) => {
      const items = section.querySelectorAll<HTMLElement>('li[data-search]');
      let visible = 0;
      items.forEach((li) => {
        const match = !q || li.dataset.search!.toLowerCase().includes(q);
        li.hidden = !match;
        if (match) visible++;
      });
      section.hidden = visible === 0;
    });
  });
</script>
