---
import { getCollection, render } from 'astro:content';
import Guide from '../../layouts/Guide.astro';

export async function getStaticPaths() {
  const entries = await getCollection('learn');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const canonical = new URL(`/learn/${entry.id}/`, Astro.site ?? Astro.url).href;
---

<Guide title={entry.data.title} description={entry.data.description} date={entry.data.date} slug={entry.id} canonical={canonical}>
  <Content />
</Guide>
